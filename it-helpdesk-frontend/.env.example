# Backend URL for the Vite dev-server proxy (dev only)
# In production, set the real API domain via your web server / reverse proxy instead.
VITE_API_TARGET=http://localhost:8000

# Public base URL baked into generated asset QR codes (build/dev time).
# Must be reachable from the device that scans the printed label (a phone),
# so it cannot be "localhost". Leave unset to fall back to the current origin.
#   - Production: your public site, e.g. https://helpdesk.example.com
#   - Dev (scan from a phone on the LAN): your machine's LAN IP, e.g. http://192.168.1.50:5173
#     and run the dev server with `npm run dev -- --host` so the phone can reach it.
# VITE_PUBLIC_URL=https://helpdesk.example.com
