# ─────────────────────────────────────────────────────────────────────────────
# IT HelpDesk — Production Environment Template
# Copy to .env on the server. NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="IT HelpDesk"
APP_ENV=production
APP_KEY=base64:                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://helpdesk.segsolar-ind.com
FRONTEND_URL=https://helpdesk.segsolar-ind.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────────────────────
# Option A: Supabase (recommended — managed, automatic backups, free tier)
#   Host and password from: Supabase Dashboard → Settings → Database
#   Use the connection pooler (port 6543, transaction mode) for web requests.
#   Direct connection (port 5432) for migrations/long-running commands.
#
#   For migrations use: DB_PORT=5432 (direct)
#   For app traffic  use: DB_PORT=6543 (pooler)

DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co    # Project ref from Supabase dashboard
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=                                    # Supabase database password
DB_SSLMODE=require
# DB_SSLROOTCERT=/var/www/certs/prod-ca-2021.crt  # Download from Supabase → Settings → SSL

# Option B: Self-hosted PostgreSQL on same server / VPS
# DB_HOST=postgres          # Docker service name if using docker-compose
# DB_PORT=5432
# DB_DATABASE=it_helpdesk
# DB_USERNAME=helpdesk
# DB_PASSWORD=
# DB_SSLMODE=prefer

# ─── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Email (Microsoft 365 SMTP) ──────────────────────────────────────────────
# Enable SMTP AUTH: M365 Admin → Users → <account> → Mail → Manage email apps
# MFA accounts: account.microsoft.com/security → App passwords
MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=helpdesk@segsolar-ind.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=helpdesk@segsolar-ind.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://helpdesk.segsolar-ind.com/api/auth/callback/google

# ─── Microsoft Azure OAuth ───────────────────────────────────────────────────
# https://portal.azure.com → Azure AD → App registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://helpdesk.segsolar-ind.com/api/auth/callback/microsoft
AZURE_TENANT_ID=common

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=helpdesk.segsolar-ind.com
SESSION_DOMAIN=.segsolar-ind.com

# ─── Security ────────────────────────────────────────────────────────────────
# Set these to anything random if not using Telescope/Pulse
TELESCOPE_ENABLED=false
PULSE_ENABLED=false
