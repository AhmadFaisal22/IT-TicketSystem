APP_NAME="IT HelpDesk"
APP_ENV=local
APP_KEY=
APP_DEBUG=false

# Local dev
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Production (uncomment when deploying)
# APP_URL=http://192.168.2.213:8088
# FRONTEND_URL=http://192.168.2.213:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=it_helpdesk
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Email — MAIL_MAILER=log sends to storage/logs/laravel.log (dev only)
# Production (Office 365): set MAIL_MAILER=smtp, fill USERNAME + PASSWORD
#   Enable SMTP AUTH: M365 Admin → Users → <account> → Mail → Manage email apps
#   MFA accounts need an App Password: account.microsoft.com/security → App passwords
MAIL_MAILER=log
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="helpdesk@company.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_LOGO_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/callback/google"

# Microsoft OAuth
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/api/auth/callback/microsoft"
AZURE_TENANT_ID=common
