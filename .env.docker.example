# ============================================================
# Docker environment file — copy to .env.docker and fill in
# ============================================================

APP_NAME="IT HelpDesk"
APP_ENV=production
APP_KEY=                          # fill after: php artisan key:generate
APP_DEBUG=false
APP_URL=https://helpdesk.segsolar-ind.com
FRONTEND_URL=https://helpdesk.segsolar-ind.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database (must match docker-compose.yml)
DB_CONNECTION=pgsql
DB_HOST=postgres                  # container name — do not change
DB_PORT=5432
DB_DATABASE=it_helpdesk
DB_USERNAME=helpdesk
DB_PASSWORD=change_this_strong_password

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://helpdesk.segsolar-ind.com/api/auth/callback/google

# Microsoft OAuth
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://helpdesk.segsolar-ind.com/api/auth/callback/microsoft
AZURE_TENANT_ID=common

# Email
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=helpdesk@segsolar-ind.com
MAIL_FROM_NAME="SEG IT HelpDesk"
