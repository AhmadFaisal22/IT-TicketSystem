# ============================================================
# Docker environment file — copy to .env.docker and fill in
# ============================================================

APP_NAME="IT HelpDesk"
APP_ENV=production
APP_KEY=                          # fill after: php artisan key:generate
APP_DEBUG=false
# Public URL of the app — every generated link (emails, password reset,
# OAuth return) derives from these two. Change here when the IP/port moves.
APP_URL=http://192.168.2.213:8088
FRONTEND_URL=http://192.168.2.213:8088

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database (must match docker-compose.yml)
DB_CONNECTION=pgsql
DB_HOST=postgres                  # container name — do not change
DB_PORT=5432
DB_DATABASE=it_helpdesk
DB_USERNAME=helpdesk
DB_PASSWORD=change_this_strong_password
DB_SSLMODE=prefer                 # local postgres container has no SSL; use 'require' for cloud DBs

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Google OAuth (unused — password login only. Google/Microsoft reject
# private-IP redirect URIs, so re-enabling SSO requires a real domain here.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-domain.example.com/api/auth/callback/google

# Microsoft OAuth (unused — see note above)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=https://your-domain.example.com/api/auth/callback/microsoft
AZURE_TENANT_ID=common

# Email
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=helpdesk@segsolar-ind.com
MAIL_FROM_NAME="SEG IT HelpDesk"
